        "    ax.set_ylabel('Gap (Observado - Sintético)')\n",
        "    ax.legend(loc='lower left', fontsize=9)\n",
        "\n",
        "plt.suptitle('Placebo Tests: Gap del tratado (rojo) vs. placebos (gris)', fontsize=13, y=1.02)\n",
        "plt.tight_layout()\n",
