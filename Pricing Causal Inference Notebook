        "pc_sorted = price_changes[sort_idx]\n",
        "dc_sorted = demand_changes[sort_idx]\n",
        "\n",
        "coeffs = np.polyfit(pc_sorted, dc_sorted, 2)\n",
        "demand_curve = np.poly1d(coeffs)\n",
        "\n",
        "# --- Curva de revenue relativo ---\n",
        "def revenue_relative(pct_dp):\n",
