        "# =====================================================================\n",
        "# INFERENCIA FORMAL: CIs para ATT + Test de Pre-Trends\n",
        "# =====================================================================\n",
        "# Los placebo tests de Fisher dan p-valores, pero no intervalos de confianza.\n",
        "# Usamos la distribución de efectos placebo para construir CIs:\n",
        "#   - Bajo H0 (sin efecto), el ATT del tratado sería un draw de la misma\n",
        "#     distribución que los ATTs de los placebos\n",
        "#   - CI = ATT ± 1.96 × σ(placebo ATTs)\n",
        "#\n",
        "# Adicionalmente, formalizamos el test de pre-trends:\n",
        "#   - Si el RMSPE pre del tratado es extremo vs. los placebos,\n",
        "#     el sintético no replica bien al tratado ANTES del tratamiento\n",
        "#     → los asunciones de identificación pueden estar comprometidas\n",
        "#\n",
        "# Ref: Abadie, Diamond, Hainmueller (2010), sección sobre inferencia;\n",
        "#      Chernozhukov, Wüthrich, Zhu (2021) para conformal inference en SCM.\n",
        "# =====================================================================\n",
        "\n",
        "print(\"=\"*70)\n",
        "print(\"INFERENCIA FORMAL: CIs Y PRE-TRENDS\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "for arm, info in TREATED_MARKETS.items():\n",
        "    rep = info['market']\n",
        "    t_day = info['treatment_day']\n",
        "    scm_result = results[arm]\n",
        "    placebos = all_placebo_results[arm]['placebos']\n",
        "\n",
        "    post_mask = scm_result['day_index'] >= t_day\n",
        "    pre_mask = scm_result['day_index'] < t_day\n",
        "\n",
        "    # --- ATT del tratado ---\n",
        "    treated_att = np.mean(scm_result['effect'][post_mask])\n",
        "    baseline_cf = np.mean(scm_result['synthetic'][post_mask])\n",
        "    treated_att_pct = (treated_att / baseline_cf) * 100\n",
        "\n",
        "    # --- Distribución de ATTs placebo ---\n",
        "    placebo_atts = []\n",
        "    placebo_rmspes_pre = []\n",
        "    for pm, scm_p in placebos.items():\n",
        "        p_post = scm_p['day_index'] >= t_day\n",
        "        p_pre = scm_p['day_index'] < t_day\n",
        "        placebo_atts.append(np.mean(scm_p['effect'][p_post]))\n",
        "        placebo_rmspes_pre.append(scm_p['rmspe_pre'])\n",
        "\n",
        "    placebo_atts = np.array(placebo_atts)\n",
        "    placebo_rmspes_pre = np.array(placebo_rmspes_pre)\n",
        "\n",
        "    # --- CI 95% basado en dispersión placebo ---\n",
        "    placebo_std = np.std(placebo_atts)\n",
        "    ci_lower = treated_att - 1.96 * placebo_std\n",
        "    ci_upper = treated_att + 1.96 * placebo_std\n",
        "    ci_lower_pct = (ci_lower / baseline_cf) * 100\n",
        "    ci_upper_pct = (ci_upper / baseline_cf) * 100\n",
        "    zero_in_ci = ci_lower <= 0 <= ci_upper\n",
        "\n",
        "    # --- Test formal de pre-trends ---\n",
        "    # H0: el ajuste pre-periodo del tratado no es peor que el de los placebos\n",
        "    # Estadístico: rank del RMSPE pre del tratado en la distribución placebo\n",
        "    treated_rmspe_pre = scm_result['rmspe_pre']\n",
        "    pre_rank = np.sum(placebo_rmspes_pre <= treated_rmspe_pre) + 1\n",
        "    pre_total = len(placebo_rmspes_pre) + 1\n",
        "    pre_percentile = pre_rank / pre_total * 100\n",
        "\n",
        "    # Pre-trends OK si el RMSPE del tratado no está en el extremo superior\n",
        "    pre_trends_ok = pre_percentile <= 80  # No peor que el 80% de los placebos\n",
        "\n",
        "    print(f\"\\n{'─'*50}\")\n",
        "    print(f\"{arm} ({rep})\")\n",
        "    print(f\"{'─'*50}\")\n",
        "\n",
        "    print(f\"\\n  Intervalos de confianza (placebo-based):\")\n",
        "    print(f\"    ATT:    {treated_att:>7.1f} bookings/día ({treated_att_pct:+.1f}%)\")\n",
        "    print(f\"    CI 95%: [{ci_lower:>7.1f}, {ci_upper:>7.1f}] bookings/día\")\n",
        "    print(f\"            [{ci_lower_pct:>+6.1f}%, {ci_upper_pct:>+6.1f}%]\")\n",
        "    print(f\"    σ(placebo): {placebo_std:.1f}\")\n",
        "    if zero_in_ci:\n",
        "        print(f\"    ⚠️ El cero cae dentro del CI → efecto no significativo al 95%\")\n",
        "    else:\n",
        "        print(f\"    ✓ El cero NO cae dentro del CI → efecto significativo al 95%\")\n",
