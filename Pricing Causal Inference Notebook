        "# =====================================================================\n",
        "# ROBUSTNESS CHECK: BSTS / CausalImpact para UK (+10%)\n",
        "# =====================================================================\n",
        "# SCM diagnosticó HHI alto para UK: el sintético depende excesivamente de DE.\n",
        "# Validamos con un método alternativo que no requiere convex hull.\n",
        "#\n",
        "# En lugar de usar pycausalimpact (dependencia frágil, rota con pandas ≥ 2.0),\n",
        "# implementamos el mismo modelo directamente con statsmodels:\n",
        "#   y_t = μ_t + β'X_t + ε_t     (observación)\n",
        "#   μ_t = μ_{t-1} + η_t          (local level = random walk)\n",
        "#\n",
        "# Esto es exactamente lo que CausalImpact (Brodersen et al., 2015) hace\n",
        "# internamente, sin la capa de abstracción que se rompe entre versiones.\n",
        "# =====================================================================\n",
        "\n",
        "from statsmodels.tsa.statespace.structural import UnobservedComponents\n",
        "\n",
        "def bsts_causal_impact(df, treated_market, control_markets, treatment_day,\n",
        "                       outcome='bookings', k_controls=6, alpha=0.05):\n",
        "    \"\"\"\n",
        "    Robustness check via Bayesian Structural Time Series.\n",
        "\n",
        "    Implementa el contrafactual de Brodersen et al. (2015) usando\n",
        "    statsmodels.UnobservedComponents:\n",
        "      1. Selecciona top-k controles por correlación pre-tratamiento\n",
        "         (sustituto del spike-and-slab prior de CausalImpact)\n",
        "      2. Ajusta Local Level + regresión en pre-periodo\n",
        "      3. Propaga contrafactual al post-periodo con Y=NaN\n",
        "         (Kalman filter sin observation update = forecast puro)\n",
        "      4. Efecto causal = observado - contrafactual\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df : DataFrame con columnas 'market', 'day_index', outcome\n",
        "    treated_market : str\n",
        "    control_markets : list of str\n",
        "    treatment_day : int (day_index, 1-based)\n",
        "    outcome : str, variable dependiente\n",
        "    k_controls : int, controles a seleccionar (n_pre/k > 10 recomendado)\n",
        "    alpha : float, nivel de significancia para IC\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict con ATT, IC, contrafactual, diagnósticos\n",
        "    \"\"\"\n",
        "    # --- Preparar series ---\n",
        "    y_full = (df[df['market'] == treated_market]\n",
        "              .sort_values('day_index')[outcome]\n",
        "              .values.astype(float))\n",
        "    n_total = len(y_full)\n",
        "    n_pre = treatment_day - 1\n",
        "    n_post = n_total - n_pre\n",
        "\n",
        "    control_data = np.column_stack([\n",
        "        df[df['market'] == m].sort_values('day_index')[outcome].values.astype(float)\n",
        "        for m in control_markets\n",
        "    ])\n",
        "\n",
        "    # --- Selección de controles por correlación pre-periodo ---\n",
        "    # CausalImpact usa spike-and-slab prior para selección automática.\n",
        "    # Aquí usamos correlación + ratio obs/regresores como guardrail.\n",
        "    pre_corrs = []\n",
        "    for j, m in enumerate(control_markets):\n",
        "        r = np.corrcoef(y_full[:n_pre], control_data[:n_pre, j])[0, 1]\n",
        "        pre_corrs.append((m, j, abs(r), r))\n",
        "    pre_corrs.sort(key=lambda x: -x[2])\n",
        "\n",
        "    max_k = max(3, n_pre // 12)  # ratio ≥ 12 para evitar sobreajuste\n",
        "    k_actual = min(k_controls, max_k, len(control_markets))\n",
        "\n",
        "    selected = pre_corrs[:k_actual]\n",
        "    selected_names = [s[0] for s in selected]\n",
        "    selected_idx = [s[1] for s in selected]\n",
        "    X = control_data[:, selected_idx]\n",
        "\n",
        "    # --- Step 1: Ajustar modelo en pre-periodo ---\n",
        "    model_pre = UnobservedComponents(\n",
        "        endog=y_full[:n_pre],\n",
        "        exog=X[:n_pre],\n",
        "        level='local level',\n",
        "    )\n",
        "    fit = model_pre.fit(disp=False, maxiter=1000)\n",
        "\n",
        "    # --- Step 2: Contrafactual con post-periodo enmascarado ---\n",
        "    # Al poner Y=NaN en post-periodo, el Kalman filter propaga el estado\n",
        "    # sin actualizar con observaciones → contrafactual puro\n",
        "    y_masked = y_full.copy()\n",
        "    y_masked[n_pre:] = np.nan\n",
        "\n",
        "    model_full = UnobservedComponents(\n",
        "        endog=y_masked,\n",
        "        exog=X,\n",
        "        level='local level',\n",
        "    )\n",
        "    result = model_full.smooth(fit.params)\n",
        "\n",
        "    # --- Step 3: Extraer contrafactual y efectos ---\n",
        "    pred = result.get_prediction()\n",
        "    cf_mean = pred.predicted_mean\n",
        "    cf_ci = pred.conf_int(alpha=alpha)\n",
        "    if hasattr(cf_ci, 'values'):\n",
        "        cf_ci = cf_ci.values\n",
        "\n",
        "    effects = y_full - cf_mean\n",
        "    effects_lower = y_full - cf_ci[:, 1]  # lower effect = y - upper pred\n",
        "    effects_upper = y_full - cf_ci[:, 0]  # upper effect = y - lower pred\n",
        "\n",
        "    # --- Resultados ---\n",
        "    att = float(np.mean(effects[n_pre:]))\n",
        "    att_ci_lower = float(np.mean(effects_lower[n_pre:]))\n",
        "    att_ci_upper = float(np.mean(effects_upper[n_pre:]))\n",
        "\n",
        "    pre_resid = effects[:n_pre]\n",
        "\n",
        "    return {\n",
        "        'att': att,\n",
        "        'att_ci_lower': att_ci_lower,\n",
        "        'att_ci_upper': att_ci_upper,\n",
        "        'counterfactual': cf_mean,\n",
        "        'effects': effects,\n",
        "        'effects_lower': effects_lower,\n",
        "        'effects_upper': effects_upper,\n",
        "        'y_actual': y_full,\n",
        "        'n_pre': n_pre,\n",
        "        'n_post': n_post,\n",
        "        'selected_controls': selected_names,\n",
        "        'pre_correlations': {s[0]: round(s[3], 3) for s in selected},\n",
        "        'aic': fit.aic,\n",
        "        'params': dict(zip(fit.param_names, fit.params)),\n",
        "        'pre_mae': float(np.mean(np.abs(pre_resid))),\n",
        "        'pre_mean_resid': float(np.mean(pre_resid)),\n",
        "        'cf_ci': cf_ci,  # shape (n_total, 2): [lower, upper] of counterfactual\n",
        "    }\n",
        "\n",
        "\n",
