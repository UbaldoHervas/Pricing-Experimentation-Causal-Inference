        "#      Esta es una simplificación operativa: en realidad, mercados con\n",
        "#      distinto GDP/tamaño pueden tener elasticidades distintas.\n",
        "#      Úsese como orientación, no como punto estimate de un mercado concreto.\n",
        "# =====================================================================\n",
        "\n",
        "from scipy.interpolate import UnivariateSpline\n",
        "from scipy.optimize import minimize_scalar\n",
        "\n",
        "# --- Datos: origen (supuesto) + tres brazos (causales) ---\n",
        "price_changes = np.array([0.0] + list(elasticity_df['price_change_realized']))\n",
        "demand_changes = np.array([0.0] + list(elasticity_df['pct_change_q']))\n",
        "\n",
